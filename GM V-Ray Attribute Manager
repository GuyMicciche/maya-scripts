# ---------------------------------------------------------------------------
# Main widget
# ---------------------------------------------------------------------------

class VRayAttributeManager(QtWidgets.QWidget):
    """Dockable Qt panel for managing V-Ray extra attributes."""

    WINDOW_TITLE = "V-Ray Attribute Manager"
    OBJECT_NAME = "vrayAttrManager_mainWidget"

    # Selection mode enum
    MODE_SHAPE = 0
    MODE_TRANSFORM = 1

    def __init__(self, parent=None):
        super().__init__(parent or _get_maya_main_window())
        self.setObjectName(self.OBJECT_NAME)
        self.setWindowTitle(self.WINDOW_TITLE)
        self.setWindowFlags(QtCore.Qt.Window)
        self.setAttribute(QtCore.Qt.WA_DeleteOnClose)
        self.setMinimumWidth(340)
        self.setMinimumHeight(300)
        self.resize(380, 520)

        self._mode = self.MODE_SHAPE
        self._callback_id = None
        self._attr_toggles = []  # list of (checkbox, group_name, check_attr) for current view
        self._search_text = ""

        self._build_ui()
        self._install_callback()
        self._on_selection_changed()

    # ------------------------------------------------------------------
    # UI construction
    # ------------------------------------------------------------------

    def _build_ui(self):
        self.setStyleSheet(_STYLESHEET)
        self.setProperty("id", "VRayAttrManager")
        self.setObjectName("VRayAttrManager")

        root = QtWidgets.QVBoxLayout(self)
        root.setContentsMargins(0, 0, 0, 0)
        root.setSpacing(0)

        # --- Header ---
        header = QtWidgets.QFrame()
        header.setObjectName("headerFrame")
        header_lay = QtWidgets.QVBoxLayout(header)
        header_lay.setContentsMargins(12, 10, 12, 10)
        header_lay.setSpacing(2)

        title = QtWidgets.QLabel("V-Ray Attribute Manager")
        title.setObjectName("titleLabel")
        header_lay.addWidget(title)

        subtitle = QtWidgets.QLabel("Manage extra attributes on selected nodes")
        subtitle.setObjectName("subtitleLabel")
        header_lay.addWidget(subtitle)

        root.addWidget(header)

        # --- Toolbar area ---
        toolbar = QtWidgets.QVBoxLayout()
        toolbar.setContentsMargins(10, 8, 10, 4)
        toolbar.setSpacing(6)

        # Mode toggle
        mode_frame = QtWidgets.QFrame()
        mode_frame.setObjectName("modeFrame")
        mode_lay = QtWidgets.QHBoxLayout(mode_frame)
        mode_lay.setContentsMargins(2, 2, 2, 2)
        mode_lay.setSpacing(2)

        self._btn_shape = QtWidgets.QPushButton("Shape")
