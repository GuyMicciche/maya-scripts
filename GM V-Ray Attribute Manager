        btn_refresh.setObjectName("batchBtn")
        btn_refresh.setCursor(QtCore.Qt.PointingHandCursor)
        btn_refresh.clicked.connect(self._on_selection_changed)
        footer_lay.addWidget(btn_refresh)

        root.addWidget(footer)

    # ------------------------------------------------------------------
    # Callback management (API 2.0 — no scriptJobs)
    # ------------------------------------------------------------------

    def _install_callback(self):
        """Register a SelectionChanged event callback via Maya API 2.0."""
        self._remove_callback()
        self._callback_id = om2.MEventMessage.addEventCallback(
            "SelectionChanged", self._selection_changed_cb
        )

    def _remove_callback(self):
        if self._callback_id is not None:
            try:
                om2.MMessage.removeCallback(self._callback_id)
            except RuntimeError:
                pass
            self._callback_id = None

    def _selection_changed_cb(self, *_args):
        """API callback — fires on Maya selection change."""
        # Defer to avoid re-entrancy during selection processing
        cmds.evalDeferred(self._on_selection_changed)

    # ------------------------------------------------------------------
    # Mode switching
    # ------------------------------------------------------------------

    def _set_mode(self, mode):
        self._mode = mode
        self._btn_shape.setProperty("active", mode == self.MODE_SHAPE)
        self._btn_transform.setProperty("active", mode == self.MODE_TRANSFORM)
        # Force style recalc
        self._btn_shape.style().unpolish(self._btn_shape)
        self._btn_shape.style().polish(self._btn_shape)
        self._btn_transform.style().unpolish(self._btn_transform)
        self._btn_transform.style().polish(self._btn_transform)
        self._on_selection_changed()

    # ------------------------------------------------------------------
    # Core refresh logic
    # ------------------------------------------------------------------

    def _on_selection_changed(self, *_args):
        """Rebuild the attribute list for the current selection."""
        self._clear_attrs()

        # Resolve selected nodes based on mode
        raw_sel = cmds.ls(sl=True, long=True) or []
        if not raw_sel:
            self._show_empty("Nothing selected")
            return

        if self._mode == self.MODE_SHAPE:
            nodes = cmds.ls(sl=True, dag=True, shapes=True, long=True) or []
        else:
            nodes = raw_sel

        if not nodes:
            short_name = raw_sel[0].rsplit("|", 1)[-1]
            mode_label = "shape" if self._mode == self.MODE_SHAPE else "transform"
            self._show_empty(f"No {mode_label} node for {short_name}")
            return

        # Determine API type from first node
        api_type = _get_api_type_str(nodes[0])
        if api_type is None:
            self._show_empty("Could not determine node type")
            return

        relevant_groups = _VRAY_ATTRS_BY_TYPE.get(api_type, [])
        if not relevant_groups:
            mode_label = "shape" if self._mode == self.MODE_SHAPE else "transform"
            self._show_empty(f"No V-Ray attributes for {api_type} ({mode_label})")
            return

        # Resolve to display entries
        entries = []  # list of (display_name, group_name, check_attr)
        for grp in relevant_groups:
            info = _GROUP_TO_DISPLAY.get(grp)
            if info:
                entries.append((info[0], grp, info[1]))

        if not entries:
            self._show_empty(f"No recognized V-Ray attributes for {api_type}")
            return

        # Show info
        short_name = nodes[0].rsplit("|", 1)[-1]
        self._info_label.setText(f"{api_type}  —  {short_name}")
        self._info_frame.setObjectName("infoBar")
        self._info_frame.style().unpolish(self._info_frame)
        self._info_frame.style().polish(self._info_frame)

        node_count = len(nodes)
        if node_count > 1:
            self._node_badge.setText(f"{node_count} nodes")
            self._node_badge.show()
        else:
            self._node_badge.hide()

        # Build attribute rows
        self._attr_toggles = []
        for display_name, group_name, check_attr in entries:
            row = self._make_attr_row(nodes, display_name, group_name, check_attr)
            # Insert before the stretch
            self._scroll_layout.insertWidget(self._scroll_layout.count() - 1, row)

        self._apply_search_filter()

    def _make_attr_row(self, nodes, display_name, group_name, check_attr):
        """Create a single attribute row widget."""
        is_on = _attr_exists(nodes[0], check_attr)

        row = QtWidgets.QFrame()
        row.setObjectName("attrRowActive" if is_on else "attrRow")
        row.setProperty("display_name", display_name)
        row_lay = QtWidgets.QHBoxLayout(row)
        row_lay.setContentsMargins(8, 6, 8, 6)
        row_lay.setSpacing(8)

        # Text column
        text_col = QtWidgets.QVBoxLayout()
        text_col.setSpacing(1)

        name_label = QtWidgets.QLabel(display_name)
        name_label.setProperty("class", "attrNameActive" if is_on else "attrName")
        text_col.addWidget(name_label)

        group_label = QtWidgets.QLabel(group_name)
        group_label.setProperty("class", "attrGroup")
        text_col.addWidget(group_label)

        row_lay.addLayout(text_col, 1)

        # Toggle
        toggle = QtWidgets.QCheckBox()
        toggle.setObjectName("attrToggle")
        toggle.setChecked(is_on)
        toggle.setCursor(QtCore.Qt.PointingHandCursor)

        # Connect with captured variables
        toggle.toggled.connect(partial(self._on_toggle, nodes, group_name, check_attr, row, name_label))

        row_lay.addWidget(toggle)

        self._attr_toggles.append((toggle, group_name, check_attr, row))
        return row

    def _on_toggle(self, nodes, group_name, check_attr, row, name_label, state):
        """Handle a single attribute toggle."""
        for node in nodes:
            try:
                _apply_attr(node, group_name, state)
            except Exception as e:
                cmds.warning(f"Failed to {'add' if state else 'remove'} {group_name} on {node}: {e}")

        # Update row visual
        row.setObjectName("attrRowActive" if state else "attrRow")
        row.style().unpolish(row)
        row.style().polish(row)
        name_label.setProperty("class", "attrNameActive" if state else "attrName")
        name_label.style().unpolish(name_label)
        name_label.style().polish(name_label)

    # ------------------------------------------------------------------
    # Batch operations
    # ------------------------------------------------------------------

    def _batch_set(self, state):
        """Enable or disable all currently visible attribute toggles."""
        for toggle, group_name, check_attr, row in self._attr_toggles:
            if not row.isHidden() and toggle.isChecked() != state:
                toggle.setChecked(state)

    # ------------------------------------------------------------------
    # Search / filter
    # ------------------------------------------------------------------

    def _on_search_changed(self, text):
        self._search_text = text.strip().lower()
        self._apply_search_filter()

    def _apply_search_filter(self):
        for toggle, group_name, check_attr, row in self._attr_toggles:
            display_name = row.property("display_name") or ""
            visible = True
            if self._search_text:
                visible = (
                    self._search_text in display_name.lower()
                    or self._search_text in group_name.lower()
                )
            row.setVisible(visible)

    # ------------------------------------------------------------------
    # Empty / warning states
    # ------------------------------------------------------------------

    def _show_empty(self, message):
        self._info_label.setText(message)
        self._info_frame.setObjectName("emptyBar")
        self._info_frame.style().unpolish(self._info_frame)
        self._info_frame.style().polish(self._info_frame)
        self._info_label.setObjectName("emptyLabel")
        self._info_label.style().unpolish(self._info_label)
        self._info_label.style().polish(self._info_label)
        self._node_badge.hide()

    def _clear_attrs(self):
        """Remove all attribute row widgets."""
        self._attr_toggles = []
        while self._scroll_layout.count() > 1:  # keep the stretch
            item = self._scroll_layout.takeAt(0)
            widget = item.widget()
            if widget:
                widget.deleteLater()

    # ------------------------------------------------------------------
    # Cleanup
    # ------------------------------------------------------------------

    def closeEvent(self, event):
        self._remove_callback()
        super().closeEvent(event)


# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

_instance = None


def show():
    """Show the V-Ray Attribute Manager window (singleton)."""
    global _instance

    # Close existing
    if _instance is not None:
        try:
            _instance.close()
            _instance.deleteLater()
        except RuntimeError:
            pass

    _instance = VRayAttributeManager()
    _instance.show()
    _instance.raise_()
    return _instance
    
show()
