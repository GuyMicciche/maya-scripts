# ---------------------------------------------------------------------------
# Utility helpers
# ---------------------------------------------------------------------------

def _get_maya_main_window():
    """Return the Maya main window as a QWidget."""
    ptr = omui.MQtUtil.mainWindow()
    if ptr is not None:
        return wrapInstance(int(ptr), QtWidgets.QWidget)
    return None


def _get_api_type_str(node_name):
    """Return the API type string for *node_name* using Maya API 2.0."""
    sel = om2.MSelectionList()
    try:
        sel.add(node_name)
    except RuntimeError:
        return None
    obj = sel.getDependNode(0)
    api_str = obj.apiTypeStr
    if api_str.startswith("kPlugin"):
        return cmds.nodeType(node_name)
    return api_str


def _attr_exists(node, check_attr):
    """Return True if *check_attr* exists on *node*."""
    return cmds.attributeQuery(check_attr, node=node, exists=True)


def _apply_attr(node, group_name, state):
    """Add or remove a V-Ray attribute group on *node*."""
    cmds.vray("addAttributesFromGroup", node, group_name, 1 if state else 0)


