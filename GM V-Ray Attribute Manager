        self._btn_transform.clicked.connect(lambda: self._set_mode(self.MODE_TRANSFORM))

        mode_lay.addWidget(self._btn_shape)
        mode_lay.addWidget(self._btn_transform)
        toolbar.addWidget(mode_frame)

        # Search bar
        search_row = QtWidgets.QHBoxLayout()
        search_row.setSpacing(6)

        self._search = QtWidgets.QLineEdit()
        self._search.setObjectName("searchField")
        self._search.setPlaceholderText("  Filter attributes...")
